# ─────────────────────────────────────────────────────────────────
# Bia Namur — template .env de production (CBlue VM Debian)
# ─────────────────────────────────────────────────────────────────
# Ce fichier est COMMITÉ : il sert de template au workflow
# .github/workflows/deploy.yml qui remplace les ${VAR} via sed ancré
# avec les GitHub Secrets correspondants.
#
# Toute valeur en clair ici doit être anodine (jamais de secret réel).
# Les ${VAR} sont des placeholders — sed les remplace au déploiement.
# ─────────────────────────────────────────────────────────────────

APP_NAME="Bia Namur"
APP_ENV=production
APP_KEY=${APP_KEY}
APP_DEBUG=false
APP_TIMEZONE=Europe/Brussels
APP_URL=${APP_URL}

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_BE

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging
# 'stack' route vers 'single' qui écrit dans storage/logs/laravel.log
# Channels métier (ingestion, ai_pipeline, moderation) configurés dans config/logging.php
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─────────────────────────────────────────────────────────────────
# Base de données — VM CBlue
# DB_HOST = 127.0.0.1 sur cette VM (pas un mutualisé cPanel)
# ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_DATABASE=${DB_DATABASE}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

# ─────────────────────────────────────────────────────────────────
# Sessions / Cache / Queue — driver database (pas de Redis sur la VM)
# ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
# Important : point initial pour iOS Safari (PWA), sécurise sur tous sous-domaines bianamur.be
SESSION_DOMAIN=${SESSION_DOMAIN}
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=bia_

# ─────────────────────────────────────────────────────────────────
# Mail — SMTP provider (Mailgun / Postmark / Resend)
# ─────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=${MAIL_HOST}
MAIL_PORT=${MAIL_PORT}
MAIL_USERNAME=${MAIL_USERNAME}
MAIL_PASSWORD=${MAIL_PASSWORD}
MAIL_FROM_ADDRESS=${MAIL_FROM_ADDRESS}
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────
# Anthropic Claude API
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_PREMIUM_MODEL=claude-opus-4-7

# ─────────────────────────────────────────────────────────────────
# Bia feature flags — production
# ─────────────────────────────────────────────────────────────────
BIA_AI_AUTO_PUBLISH=false
BIA_SRC_OPENDATA=true
BIA_SRC_RSS_DELTA=true
BIA_SRC_QUEFAIRE=false
# Mode mock OFF en prod : Claude réel actif (vérifié en local d'abord)
BIA_AI_MOCK_MODE=false
BIA_INGEST_FIXTURE_MODE=false
BIA_USER_AGENT="BiaNamurBot/1.0 (+contact@bianamur.be)"

# ─────────────────────────────────────────────────────────────────
# Push notifications PWA (minishlink/web-push)
# IMPORTANT : BIA_VAPID_PUBLIC_KEY et VITE_VAPID_PUBLIC_KEY DOIVENT
# avoir la même valeur (clé publique = front + back), sinon
# InvalidStateError côté client.
# ─────────────────────────────────────────────────────────────────
BIA_VAPID_PUBLIC_KEY=${BIA_VAPID_PUBLIC_KEY}
BIA_VAPID_PRIVATE_KEY=${BIA_VAPID_PRIVATE_KEY}
BIA_VAPID_SUBJECT=${BIA_VAPID_SUBJECT}
VITE_VAPID_PUBLIC_KEY=${BIA_VAPID_PUBLIC_KEY}

# ─────────────────────────────────────────────────────────────────
# Cloudflare R2 (médias) — vide tant que pas activé
# ─────────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID}
R2_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY}
R2_BUCKET=${R2_BUCKET}
R2_ENDPOINT=${R2_ENDPOINT}
R2_PUBLIC_URL=${R2_PUBLIC_URL}
R2_REGION=auto

# ─────────────────────────────────────────────────────────────────
# Sentry monitoring
# ─────────────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=${SENTRY_LARAVEL_DSN}

# ─────────────────────────────────────────────────────────────────
# Endpoint /migrate — utilisé en plan B si SSH down
# (en prod CBlue on a SSH donc ce secret reste un fallback)
# ─────────────────────────────────────────────────────────────────
MIGRATE_SECRET=${MIGRATE_SECRET}

# ─────────────────────────────────────────────────────────────────
# Vite — variables côté front (préfixe VITE_ obligatoire)
# Sont buildées dans les bundles JS/CSS — ne pas mettre de secret ici.
# ─────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
