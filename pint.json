{
    "preset": "laravel",
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor",
        "node_modules",
        "public/build"
    ],
    "rules": {
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "concat_space": {
            "spacing": "one"
        },
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays", "arguments", "match", "parameters"]
        }
    }
}
