APP_NAME="Bia Namur"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Brussels
APP_URL=http://bia-namur.test

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_BE

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de donnees
# Local Laragon : DB_HOST=127.0.0.1
# Production FTP shared hosting : DB_HOST=localhost (PAS 127.0.0.1)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bia_namur_local
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=bia_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
# Local Laragon : Mailpit sur 127.0.0.1:1025
# Production : SMTP provider (Mailgun / Postmark / etc.)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@bianamur.be"
MAIL_FROM_NAME="${APP_NAME}"

# Anthropic Claude API
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_PREMIUM_MODEL=claude-opus-4-7

# Bia feature flags
BIA_AI_AUTO_PUBLISH=false
BIA_SRC_OPENDATA=true
BIA_SRC_RSS_DELTA=true
BIA_SRC_QUEFAIRE=false
BIA_AI_MOCK_MODE=true
BIA_INGEST_FIXTURE_MODE=true
BIA_USER_AGENT="BiaNamurBot/1.0 (+contact@bianamur.be)"

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bianamur-media
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_REGION=auto

# Sentry
SENTRY_LARAVEL_DSN=

# Migration endpoint secret (production FTP only)
MIGRATE_SECRET=

# Vite
VITE_APP_NAME="${APP_NAME}"
